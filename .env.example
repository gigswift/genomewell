# Chronic Wellness — Environment Variables
# Copy this file to .env and fill in the values before running the dev server.
#
# Get your API key at: https://console.anthropic.com/
#
# IMPORTANT: For production, proxy the Claude API call through a serverless function
# (e.g. a Vercel Edge Function) so this key is never exposed client-side.
# This MVP uses a direct browser call for simplicity.

VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Affiliate IDs — one per partner. Set whichever programs have approved the
# account; unset partners fall back to a placeholder ID that will not attribute
# commission. Add a new partner by adding its enum entry + env var — no code
# paths hardcode a single partner.
VITE_THORNE_AFFILIATE_ID=
VITE_BIOTRUST_AFFILIATE_ID=
VITE_ORGANIFI_AFFILIATE_ID=

